# Server
PORT=3000
NODE_ENV=development

# MongoDB — local (no auth)
# MONGODB_URI=mongodb://localhost:27017

# MongoDB — with Docker (auth enabled)
MONGODB_URI=mongodb://admin:changeme123@localhost:27017/crud-express?authSource=admin

DB_NAME=crud-express

# JWT — generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change_this_to_a_secure_random_value

# Logging
LOG_RETENTION_DAYS=30
LOG_MAX_SIZE=20m
SERVICE_NAME=crud-express

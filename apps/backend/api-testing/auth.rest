###
### 1. Register a new user
POST {{baseUrl}}/register
Content-Type: application/json

{
    "name": "John Doe",
    "username": "johndoe1",
    "password": "password123"
}

###
### 2. Register - Missing fields (should fail with 400)
POST {{baseUrl}}/register
Content-Type: application/json

{
    "name": "Jane Doe"
}

###
### 3. Register - Short password (should fail with 400)
POST {{baseUrl}}/register
Content-Type: application/json

{
    "name": "Jane Doe",
    "username": "janedoe",
    "password": "123"
}

###
### 4. Register - Duplicate username (should fail with 409)
POST {{baseUrl}}/register
Content-Type: application/json

{
    "name": "John Duplicate",
    "username": "johndoe",
    "password": "password123"
}

###
### 5. Login with valid credentials
# @name login
POST {{baseUrl}}/login
Content-Type: application/json

{
    "username": "joni",
    "password": "admin123"
}

###
### 6. Login - Invalid credentials (should fail with 401)
POST {{baseUrl}}/login
Content-Type: application/json

{
    "username": "joni",
    "password": "wrongpassword"
}

###
### 7. Login - Missing fields (should fail with 400)
POST {{baseUrl}}/login
Content-Type: application/json

{
    "username": "joni"
}

###
### 8. WhoAmI - Get current authenticated user
# Requires token from login response
GET {{baseUrl}}/whoami
Authorization: Bearer {{token}}

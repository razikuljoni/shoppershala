# ============================================
# Shoppershala — Environment Variables
# ============================================
# Copy this file to .env in apps/backend/ and fill values
#   cp apps/backend/.env.example apps/backend/.env

# Server
PORT=3000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb://localhost:27017
DB_NAME=crud-express

# JWT
JWT_SECRET=change_this_to_a_secure_random_value

# Logging
LOG_RETENTION_DAYS=30
LOG_MAX_SIZE=20m
SERVICE_NAME=crud-express
